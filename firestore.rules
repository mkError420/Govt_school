rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mk.rabbani.cse@gmail.com' && request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidNotice(incoming());
      allow update: if isAdmin() && isValidNotice(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'date', 'category', 'fileUrl', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    function isValidNotice(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.date is string && data.date.size() <= 50 &&
             data.category in ['General', 'Exam', 'Event', 'Holiday'];
    }

    // Teachers & Staff
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /staff/{staffId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Academic Docs
    match /academic_docs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
